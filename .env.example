# Firebase Configuration
# ========================
# These are the Firebase credentials for the MixVy application.
# 
# NOTE: Web API keys are inherently public and cannot be kept secret in a browser environment.
# These are restricted to specific Firebase services via Firebase Security Rules and App Check.
# Never share your Firestore Security Rules or Firebase Admin SDK credentials.

# Web Firebase Configuration (PUBLIC - Safe to expose)
FIREBASE_API_KEY_WEB=your_web_api_key_here
FIREBASE_APP_ID_WEB=your_web_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Android Firebase Configuration (PUBLIC - Safe to expose)
FIREBASE_API_KEY_ANDROID=your_android_api_key_here
FIREBASE_APP_ID_ANDROID=your_android_app_id_here
FIREBASE_ANDROID_CLIENT_ID=your_android_client_id

# iOS Firebase Configuration (PUBLIC - Safe to expose)
FIREBASE_API_KEY_IOS=your_ios_api_key_here
FIREBASE_APP_ID_IOS=your_ios_app_id_here
FIREBASE_IOS_CLIENT_ID=your_ios_client_id
FIREBASE_IOS_BUNDLE_ID=your_ios_bundle_id

# Windows Firebase Configuration (PUBLIC - Safe to expose)
FIREBASE_API_KEY_WINDOWS=your_windows_api_key_here
FIREBASE_APP_ID_WINDOWS=your_windows_app_id_here
FIREBASE_MEASUREMENT_ID_WINDOWS=your_windows_measurement_id

# Environment
APP_VERSION=dev-local
ENVIRONMENT=development

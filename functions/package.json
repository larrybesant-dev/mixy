{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "lint": "eslint .",
    "test": "node --test test/payments.spec.js test/moderation.spec.js test/incoming_call_push.spec.js",
    "test:rules": "firebase --config ../firebase.json emulators:exec --project mixvy-rules-test --only firestore \"node --test test/firestore_rules.spec.js\"",
    "backfill:transactions:participants": "node scripts/backfill-transactions-participants.js",
    "backfill:transactions:participants:apply": "node scripts/backfill-transactions-participants.js --apply",
    "repair:conversations": "node scripts/repair-conversations.js",
    "repair:conversations:apply": "node scripts/repair-conversations.js --apply",
    "repair:messages": "node scripts/repair-messages.js",
    "repair:messages:apply": "node scripts/repair-messages.js --apply",
    "repair:messages:purge": "node scripts/repair-messages.js --apply --purge-invalid",
    "repair:rooms": "node scripts/repair-rooms.js",
    "repair:rooms:apply": "node scripts/repair-rooms.js --apply",
    "repair:follows": "node scripts/repair-follows.js",
    "repair:follows:apply": "node scripts/repair-follows.js --apply",
    "repair:all": "node scripts/repair-conversations.js && node scripts/repair-messages.js && node scripts/repair-rooms.js && node scripts/repair-follows.js",
    "repair:all:apply": "node scripts/repair-conversations.js --apply && node scripts/repair-messages.js --apply && node scripts/repair-rooms.js --apply && node scripts/repair-follows.js --apply",
    "validate": "node scripts/validate-firestore-truth.js",
    "validate:json": "node scripts/validate-firestore-truth.js --json",
    "validate:sample": "node scripts/validate-firestore-truth.js --sample 1000",
    "predeploy:validate": "node scripts/validate-firestore-truth.js",
    "stress": "node scripts/stress-test-harness.js",
    "stress:apply": "node scripts/stress-test-harness.js --users 5 --messages 20 --rounds 3",
    "ship": "node scripts/ship-checklist.js",
    "ship:json": "node scripts/ship-checklist.js --json",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "agora-access-token": "^2.0.4",
    "dotenv": "^17.4.1",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0",
    "firebase-functions-test": "^3.4.1"
  },
  "private": true
}

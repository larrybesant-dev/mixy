rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // ============================================================
    // USER DOCUMENTS (profiles, tiers)
    // ============================================================
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && !("tier" in request.resource.data.keys());
      allow update: if request.auth.token.backend == true; // Backend only for tier updates
    }

    // ============================================================
    // PUBLIC PROFILES
    // ============================================================
    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isOwner(userId);
    }

    // ============================================================
    // ROOMS & MESSAGING
    // ============================================================
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if resource.data.hostId == request.auth.uid;

      match /members/{memberId} {
        allow read: if true;
        allow create: if isSignedIn() && request.auth.uid == memberId;
        allow update, delete: if isSignedIn() && request.auth.uid == memberId;
      }

      match /messages/{messageId} {
        allow read: if true;
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }

    // ============================================================
    // USER SUBCOLLECTIONS
    // ============================================================
    match /users/{userId}/friends/{friendId} {
      allow read: if isSignedIn() && (isOwner(userId) || request.auth.uid == friendId);
      allow create, delete: if isSignedIn() && isOwner(userId);
    }

    match /users/{userId}/creations/{creationId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isSignedIn() && isOwner(userId);
    }

    match /users/{userId}/purchases/{packId} {
      allow get, list: if isOwner(userId);
      allow create: if request.auth.token.backend == true;
      allow update, delete: if false;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn();
      allow update, delete: if isOwner(userId);
    }

    match /users/{userId}/matches/{matchId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn();
      allow update, delete: if isOwner(userId);
    }

    // ============================================================
    // PACKS (Global Marketplace)
    // ============================================================
    match /packs/{packId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ============================================================
    // PUBLISH RECORDS
    // ============================================================
    match /publish/{creationId} {
      allow create: if isSignedIn() && request.auth.token.tier in ["premium", "creatorPro"];
      allow update, delete: if false;
    }

    // ============================================================
    // EVENTS & ATTENDANCE
    // ============================================================
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();

      match /attendees/{attendeeId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn() && isOwner(attendeeId);
      }
    }

    // ============================================================
    // BLOCKING
    // ============================================================
    match /users/{userId}/blocked/{blockedUserId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && blockedUserId != userId;
      allow delete: if isOwner(userId);
    }

    // ============================================================
    // CHAT & MESSAGES (top-level)
    // ============================================================
    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }

    // ============================================================
    // WALLETS
    // ============================================================
    match /wallets/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create, update: if isSignedIn() && isOwner(userId);
    }

    // ============================================================
    // PRESENCE & HEARTBEAT (User online status)
    // ============================================================
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isOwner(userId);
    }

    match /heartbeat/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isOwner(userId);
    }

    // ============================================================
    // CATCH-ALL (Deny all by default)
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isFriendLinkUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
        && (
          request.resource.data.friends.hasAny([request.auth.uid])
          || resource.data.friends.hasAny([request.auth.uid])
        );
    }

    function isAllowedUserProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'username',
        'email',
        'avatarUrl',
        'coverPhotoUrl',
        'galleryUrls',
        'introVideoUrl',
        'bio',
        'aboutMe',
        'age',
        'gender',
        'location',
        'relationshipStatus',
        'vibePrompt',
        'firstDatePrompt',
        'musicTastePrompt',
        'interests',
        'themeId',
        'camViewPolicy',
        'adultModeEnabled',
        'adultConsentAccepted',
        'updatedAt'
      ]);
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function adultModeEnabled(userId) {
      return userDoc(userId).data.adultModeEnabled == true
        && userDoc(userId).data.adultConsentAccepted == true;
    }

    function canReadSharedAdultProfile(userId) {
      return signedIn() && adultModeEnabled(request.auth.uid) && adultModeEnabled(userId);
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isRoomHost(roomId) {
      return signedIn() && (
        roomDoc(roomId).data.ownerId == request.auth.uid
        || roomDoc(roomId).data.hostId == request.auth.uid
      );
    }

    function participantDoc(roomId, userId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(userId));
    }

    function participantRole(roomId, userId) {
      return participantDoc(roomId, userId).data.role;
    }

    function isRoomModerator(roomId) {
      return signedIn() && participantRole(roomId, request.auth.uid) == 'moderator';
    }

    function isRoomStaff(roomId) {
      return isRoomHost(roomId) || isRoomModerator(roomId);
    }

    function isRoomParticipant(roomId) {
      return signedIn()
        && participantDoc(roomId, request.auth.uid).data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId);
      allow update: if (isSelf(userId) && isAllowedUserProfileUpdate())
        || (signedIn() && isFriendLinkUpdate());
      allow delete: if isSelf(userId);

      match /stories/{storyId} {
        allow read: if signedIn();
        allow create: if isSelf(userId)
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSelf(userId)
          && resource.data.userId == request.auth.uid;
      }

      match /adult_profile/{documentId} {
        allow read: if isSelf(userId)
          || (canReadSharedAdultProfile(userId)
            && resource.data.visibility == 'optedInAdultsOnly');
        allow create, update, delete: if isSelf(userId);
      }

      match /privacy/{documentId} {
        allow read, create, update, delete: if isSelf(userId);
      }

      match /bookmarks/{bookmarkId} {
        allow read: if isSelf(userId);
        allow create: if isSelf(userId)
          && request.resource.data.postId is string;
        allow delete: if isSelf(userId);
        allow update: if false;
      }

      match /followers/{followerId} {
        allow read: if signedIn();
        allow create, update, delete: if false;
      }

      match /following/{followingId} {
        allow read: if signedIn();
        allow create, update, delete: if false;
      }
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && (
          request.resource.data.ownerId == request.auth.uid
          || request.resource.data.hostId == request.auth.uid
        );
      // Host can update/delete; callee can decline an incoming direct call.
      allow update: if isRoomHost(roomId)
        || (signedIn()
          && resource.data.isDirectCall == true
          && resource.data.calleeId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['callDeclined', 'callDeclinedAt']));
      allow delete: if isRoomHost(roomId);

      match /members/{memberId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && memberId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.role in ['owner', 'mod', 'member'];
        allow update: if memberId == request.auth.uid || isRoomHost(roomId);
        allow delete: if memberId == request.auth.uid || isRoomHost(roomId);
      }

      match /participants/{participantId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && participantId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.role in ['audience', 'host', 'cohost', 'moderator', 'stage', 'owner', 'mod', 'member']
          && request.resource.data.isBanned == false
          && request.resource.data.isMuted == false;
        allow update: if isRoomHost(roomId)
          || (
            participantId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['lastActiveAt', 'camOn', 'micOn'])
          );
        allow delete: if isRoomHost(roomId) || participantId == request.auth.uid;
      }

      match /presence/{userId} {
        allow read: if signedIn();
        allow create, update, delete: if isRoomHost(roomId) || userId == request.auth.uid;
      }

      match /typing/{userId} {
        allow read: if signedIn();
        allow create, update, delete: if userId == request.auth.uid;
      }

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isRoomHost(roomId) || resource.data.senderId == request.auth.uid;

        match /reactions/{userId} {
          allow read: if signedIn();
          allow create, update, delete: if userId == request.auth.uid;
        }
      }

      match /policies/{documentId} {
        allow read: if signedIn();
        allow create, update, delete: if isRoomHost(roomId);
      }

      match /gift_events/{giftEventId} {
        allow read: if signedIn() && isRoomParticipant(roomId);
        allow create, update, delete: if false;
      }

      match /cam_access_requests/{requestId} {
        allow read: if signedIn()
          && (resource.data.requesterId == request.auth.uid
            || resource.data.broadcasterId == request.auth.uid
            || isRoomStaff(roomId)
            || isRoomParticipant(roomId));
        allow create: if signedIn()
          && request.resource.data.requesterId == request.auth.uid
          && request.resource.data.broadcasterId is string
          && request.resource.data.roomId == roomId
          && request.resource.data.status == 'pending';
        allow update: if signedIn()
          && (resource.data.broadcasterId == request.auth.uid || isRoomStaff(roomId));
        allow delete: if false;
      }

      match /mic_access_requests/{requestId} {
        allow read: if signedIn()
          && (resource.data.requesterId == request.auth.uid
            || resource.data.hostId == request.auth.uid
            || isRoomStaff(roomId)
            || isRoomParticipant(roomId));
        allow create: if signedIn()
          && request.resource.data.requesterId == request.auth.uid
          && request.resource.data.hostId is string
          && request.resource.data.roomId == roomId
          && request.resource.data.status == 'pending'
          && request.resource.data.priority is int
          && request.resource.data.priority >= 0
          && request.resource.data.expiresAt is timestamp;
        allow update: if signedIn() && isRoomStaff(roomId);
        allow delete: if false;
      }

      // Camera broadcaster slots.
      // Slots are single-field docs: { userId: string }.
      // A vacant slot has no document or an empty userId.
      match /slots/{slotId} {
        // Any signed-in user in a room can read the slot list (drives CameraWall).
        allow read: if signedIn();

        // Claim a vacant slot: only the requesting user can set their own userId.
        allow create: if signedIn()
          && request.resource.data.keys().hasOnly(['userId'])
          && request.resource.data.userId == request.auth.uid;

        // Update: re-confirm own slot (same userId) OR take a genuinely vacant
        // slot (existing userId is absent or empty).  Host may also clear slots.
        allow update: if isRoomHost(roomId)
          || (signedIn()
            && request.resource.data.keys().hasOnly(['userId'])
            && request.resource.data.userId == request.auth.uid
            && (
              !('userId' in resource.data)
              || resource.data.userId == ''
              || resource.data.userId == request.auth.uid
            ));

        // Release (delete): only the slot owner or the room host.
        allow delete: if signedIn()
          && (resource.data.userId == request.auth.uid || isRoomHost(roomId));
      }
      // WebRTC signaling — peer presence and P2P call documents.
      match /webrtc_peers/{userId} {
        allow read: if signedIn();
        allow create: if signedIn() && userId == request.auth.uid;
        allow update: if signedIn() && userId == request.auth.uid;
        allow delete: if signedIn() && userId == request.auth.uid;
      }

      match /webrtc_calls/{callId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.viewerId == request.auth.uid;
        allow update: if signedIn()
          && (resource.data.broadcasterId == request.auth.uid
            || resource.data.viewerId == request.auth.uid);
        allow delete: if signedIn()
          && (resource.data.viewerId == request.auth.uid || isRoomHost(roomId));

        match /viewer_ice/{docId} {
          allow read, write: if signedIn();
        }

        match /broadcaster_ice/{docId} {
          allow read, write: if signedIn();
        }
      }
    }

    match /userCamPermissions/{userId} {
      allow read: if isSelf(userId);
      allow create, update: if isSelf(userId)
        && request.resource.data.keys().hasOnly(['allowedViewers', 'updatedAt'])
        && request.resource.data.allowedViewers is list;
      allow delete: if isSelf(userId);
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && (!('authorId' in request.resource.data) || request.resource.data.authorId == request.auth.uid)
        && (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
      allow update, delete: if signedIn()
        && ((('authorId' in resource.data) && resource.data.authorId == request.auth.uid)
          || (('userId' in resource.data) && resource.data.userId == request.auth.uid));
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn()
        && ((('hostId' in resource.data) && resource.data.hostId == request.auth.uid)
          || (('ownerId' in resource.data) && resource.data.ownerId == request.auth.uid)
          || (('userId' in resource.data) && resource.data.userId == request.auth.uid));
    }

    match /transactions/{transactionId} {
      allow read: if signedIn()
        && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    match /friend_requests/{requestId} {
      allow read: if signedIn()
        && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.toUserId == request.auth.uid;
    }

    match /friends/{friendId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId is string
        && request.resource.data.actorId is string
        && request.resource.data.type is string
        && request.resource.data.content is string
        && request.resource.data.actorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      allow delete: if false;
    }

    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.followerUserId == request.auth.uid
        && request.resource.data.followedUserId is string
        && request.resource.data.followedUserId != request.auth.uid;
      allow update: if false;
      allow delete: if signedIn() && resource.data.followerUserId == request.auth.uid;
    }

    match /refund_requests/{requestId} {
      allow read: if signedIn()
        && (resource.data.requesterId == request.auth.uid
          || resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /cash_out_requests/{requestId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    match /stripe_connect_accounts/{userId} {
      allow read: if isSelf(userId);
      allow create, update, delete: if false;
    }

    match /wallets/{userId} {
      allow read: if isSelf(userId);
      allow create, update, delete: if false;
    }

    match /wallet_ledger/{entryId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /referral_codes/{code} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /referrals/{referralId} {
      allow read: if signedIn()
        && (resource.data.referrerUserId == request.auth.uid
          || resource.data.referredUserId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /referral_earnings/{earningId} {
      allow read: if signedIn() && resource.data.beneficiaryUserId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /blocks/{blockId} {
      allow read: if signedIn()
        && (resource.data.blockerUserId == request.auth.uid
          || resource.data.blockedUserId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.blockerUserId == request.auth.uid
        && request.resource.data.blockedUserId is string;
      allow update: if false;
      allow delete: if signedIn() && resource.data.blockerUserId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow read: if signedIn() && resource.data.reporterUserId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.reporterUserId == request.auth.uid
        && request.resource.data.targetId is string
        && request.resource.data.targetType is string
        && request.resource.data.reason is string;
      allow update, delete: if false;
    }

    match /beta_feedback/{feedbackId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'category',
          'message',
          'route',
          'uid',
          'email',
          'platform',
          'isWeb',
          'status',
          'createdAt'
        ])
        && request.resource.data.category in ['bug', 'ux', 'performance', 'feature-request']
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 4000
        && request.resource.data.route is string
        && request.resource.data.route.size() > 0
        && request.resource.data.route.size() <= 500
        && request.resource.data.uid == request.auth.uid
        && (
          !('email' in request.resource.data)
          || request.resource.data.email == null
          || request.resource.data.email is string
        )
        && request.resource.data.platform is string
        && request.resource.data.isWeb is bool
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if false;
    }

    match /speed_dating_actions/{actionId} {
      allow read: if signedIn()
        && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create, update: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.decision in ['like', 'pass'];
      allow delete: if false;
    }

    match /speed_dating_matches/{matchId} {
      allow read: if signedIn() && resource.data.participantIds.hasAny([request.auth.uid]);
      allow create: if signedIn()
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 2
        && request.resource.data.participantIds.hasAny([request.auth.uid]);
      allow update: if signedIn()
        && resource.data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['latestRoomId', 'updatedAt', 'lastActionBy', 'createdAt', 'participantIds']);
      allow delete: if false;
    }

    match /admin/{document=**} {
      allow read, write: if false;
    }

    match /logs/{logId} {
      allow read, write: if false;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn()
        && resource.data.participantIds.hasAny([request.auth.uid]);
      allow create: if signedIn()
        && request.resource.data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.participantIds is list;
      allow update: if signedIn()
        && resource.data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessage', 'lastMessagePreview', 'lastMessageSenderId',
                      'lastMessageAt', 'updatedAt', 'isArchived', 'unreadCounts',
                      'lastReadAt', 'status', 'typingStatus']);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn()
          && get(/databases/$(database)/documents/conversations/$(conversationId))
              .data.participantIds.hasAny([request.auth.uid]);
        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && get(/databases/$(database)/documents/conversations/$(conversationId))
              .data.participantIds.hasAny([request.auth.uid]);
        allow update, delete: if false;

        match /reactions/{reactionUserId} {
          allow read: if signedIn()
            && get(/databases/$(database)/documents/conversations/$(conversationId))
                .data.participantIds.hasAny([request.auth.uid]);
          allow create, update: if signedIn()
            && reactionUserId == request.auth.uid
            && get(/databases/$(database)/documents/conversations/$(conversationId))
                .data.participantIds.hasAny([request.auth.uid]);
          allow delete: if signedIn() && reactionUserId == request.auth.uid;
        }
      }
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.memberIds.hasAny([request.auth.uid]);
      allow update: if signedIn()
        && resource.data.memberIds.hasAny([request.auth.uid]);
      allow delete: if signedIn()
        && resource.data.creatorId == request.auth.uid;

      match /posts/{postId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && get(/databases/$(database)/documents/groups/$(groupId))
              .data.memberIds.hasAny([request.auth.uid]);
        allow update, delete: if signedIn()
          && resource.data.authorId == request.auth.uid;
      }
    }

    match /hashtags/{hashtag} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Flutter app",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"chrome"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Build Flutter Web App",
			"type": "shell",
			"command": "flutter",
			"args": [
				"build",
				"web",
				"--release",
				"--base-href",
				"/"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Build Flutter Web App (no renderer flag)",
			"type": "shell",
			"command": "flutter",
			"args": [
				"build",
				"web",
				"--release",
				"--base-href",
				"/"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Flutter Clean",
			"type": "shell",
			"command": "flutter",
			"args": [
				"clean"
			],
			"group": "build",
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent"
			}
		},
		{
			"label": "Patch Flutter Web Runtime",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"tools/patch_flutter_web_runtime.ps1"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Build Flutter Web App (patched)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"flutter build web --release --base-href '/' ; powershell -ExecutionPolicy Bypass -File tools/patch_flutter_web_runtime.ps1"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Build Flutter Web App (versioned + patched)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$ver = Get-Date -Format 'yyyy.MM.dd.HHmm'; flutter build web --release --base-href '/' --dart-define=APP_VERSION=$ver ; powershell -ExecutionPolicy Bypass -File tools/patch_flutter_web_runtime.ps1"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Audit Dart File Integrity",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"tools/audit_dart_file_integrity.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		}
	]
}

# Copy this file to assets/env/app_env and fill in your values.
# NEVER commit the real app_env file to version control.

AGORA_APP_ID=your_agora_app_id_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
FIREBASE_API_KEY_WEB=your_firebase_web_api_key_here
FIREBASE_API_KEY_WINDOWS=your_firebase_windows_api_key_here

# TURN server — required for reliable P2P when users are on different ISPs / NAT types.
# Production: replace placeholders below with your dedicated TURN credentials.
# Recommended: Metered.ca (https://dashboard.metered.ca) — free tier available.
# Also supported: Twilio NTS, Xirsys, or self-hosted coturn.
TURN_URL=turn:YOUR_ACCOUNT.relay.metered.ca:80
TURN_USERNAME=YOUR_METERED_USERNAME
TURN_CREDENTIAL=YOUR_METERED_CREDENTIAL
# Secondary TURN over TLS (port 443) — add when your plan supports it:
# TURN_URL=turns:YOUR_ACCOUNT.relay.metered.ca:443
